<?xml version="1.0" encoding="utf-8"?>
<!--
    Configuration de sécurité réseau pour Frollot.
    
    IMPORTANT: Le cleartext (HTTP) est UNIQUEMENT autorisé pour :
    - localhost (développement web)
    - 10.0.2.2 (émulateur Android)
    - 192.168.x.x (développement réseau local)
    
    En production, toutes les connexions utilisent HTTPS.
-->
<network-security-config>
    
    <!-- Configuration par défaut : HTTPS uniquement -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    
    <!-- Exceptions pour le développement local uniquement -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Émulateur Android -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Localhost -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <!-- Réseau local (pour tests sur devices physiques) -->
        <domain includeSubdomains="true">192.168.0.0</domain>
        <domain includeSubdomains="true">192.168.1.0</domain>
    </domain-config>
    
    <!-- Domaines de production : HTTPS strict -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">frollot.com</domain>
        <domain includeSubdomains="true">api.frollot.com</domain>
        <domain includeSubdomains="true">staging-api.frollot.com</domain>
    </domain-config>
    
</network-security-config>

