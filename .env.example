# ╔════════════════════════════════════════════════════════════════════════════╗
# ║                    FROLLOT - EXEMPLE DE CONFIGURATION                       ║
# ║                                                                            ║
# ║  Copiez ce fichier vers .env et modifiez les valeurs selon votre env.     ║
# ║  NE JAMAIS COMMITTER LE FICHIER .env AVEC DES SECRETS !                    ║
# ╚════════════════════════════════════════════════════════════════════════════╝

# =========================
# 🗄️ MySQL (Docker Compose)
# =========================
MYSQL_ROOT_PASSWORD=CHANGE_ME_secure_root_password
MYSQL_DATABASE=coiffure_db
MYSQL_USER=coiffure_user
MYSQL_PASSWORD=CHANGE_ME_secure_password

# =========================
# 🔌 Base de données (Spring Boot)
# =========================
DB_URL=jdbc:mysql://localhost:3307/coiffure_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=coiffure_user
DB_PASSWORD=CHANGE_ME_secure_password

# =========================
# 🔐 JWT / SÉCURITÉ (CRITIQUE)
# =========================
# Générer avec: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48
JWT_EXPIRATION_HOURS=24
JWT_EXPIRATION_MINUTES=15

# =========================
# 📦 JPA / Hibernate
# =========================
JPA_DDL_AUTO=validate
JPA_FORMAT_SQL=false
JPA_SHOW_SQL=false

# =========================
# 🔄 Flyway
# =========================
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true

# =========================
# 📧 Email / SMTP
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=no-reply@frollot.com
EMAIL_ENABLED=false

# =========================
# 🔔 Firebase
# =========================
FIREBASE_ENABLED=false
FIREBASE_SERVICE_ACCOUNT_PATH=firebase/service-account-key.json

# =========================
# 💳 Stripe
# =========================
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# =========================
# 📊 Logging
# =========================
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_FROLLOT=DEBUG
LOG_LEVEL_HIBERNATE_SQL=WARN
LOG_LEVEL_HIBERNATE_BINDER=WARN
LOG_LEVEL_SPRING_WEB=WARN
LOG_LEVEL_SPRINGDOC=WARN

# =========================
# 🌍 Environnement
# =========================
SPRING_PROFILES_ACTIVE=dev